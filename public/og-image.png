<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a0a0f"/>
      <stop offset="100%" style="stop-color:#1a1a2e"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#6366f1"/>
      <stop offset="100%" style="stop-color:#8b5cf6"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <rect x="40" y="40" width="1120" height="550" rx="20" fill="none" stroke="url(#accent)" stroke-width="2" opacity="0.3"/>
  <text x="600" y="280" font-family="system-ui, sans-serif" font-size="72" font-weight="bold" fill="white" text-anchor="middle">Girish Lade</text>
  <text x="600" y="350" font-family="system-ui, sans-serif" font-size="28" fill="#a1a1aa" text-anchor="middle">UX/UI Designer &amp; Developer</text>
  <rect x="500" y="400" width="200" height="4" rx="2" fill="url(#accent)"/>
  <text x="600" y="480" font-family="system-ui, sans-serif" font-size="20" fill="#71717a" text-anchor="middle">Open Source Portfolio</text>
</svg>